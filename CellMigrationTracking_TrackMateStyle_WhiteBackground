% Obtain data file details and read data
[fileName, filePath] = uigetfile('*', 'Select the File Containing Cell Tracking Coordinates');
% Adjust reading scope of file
opts = detectImportOptions(fullfile(filePath, fileName));
opts.DataLines = [5 Inf]; % DataLines for TrackMate exported csv format, DataRange for xlsx
opts.VariableNamesLine = 1;
trackTable = readtable(fullfile(filePath, fileName), opts);

if ismember('POSITION_T', trackTable.Properties.VariableNames)
    timeSortVar = 'POSITION_T';
else
    timeSortVar = 'FRAME';
end

% Reorganize data into a struct
trackIDs = unique(trackTable.TRACK_ID, 'stable');
fileName = extractBefore(fileName, ' data for plotting');

dataStruct = struct();

for i = 1:numel(trackIDs)
    trackID = trackIDs(i);
    currentID = trackTable.TRACK_ID == trackID;
    sortedTable = sortrows(trackTable(currentID, :), timeSortVar);

    dataStruct(i).TrackID = trackID;
    dataStruct(i).FileName = fileName;
    dataStruct(i).Time = sortedTable.(timeSortVar);
    dataStruct(i).XYZ.X = sortedTable.POSITION_X;
    dataStruct(i).XYZ.Y = sortedTable.POSITION_Y;
    dataStruct(i).XYZ.Z = sortedTable.POSITION_Z;
end

% Use the last track as reference for correction
if numel(dataStruct) < 2
    error('At least two tracks are required: one reference track and one corrected track.');
end

registrationRefTrack = dataStruct(end);
refTime = registrationRefTrack.Time;
refX = registrationRefTrack.XYZ.X;
refY = registrationRefTrack.XYZ.Y;
refZ = registrationRefTrack.XYZ.Z;

% Correct all tracks above
correctedDataStruct = struct();

for i = 1:numel(dataStruct) - 1
    currentTrack = dataStruct(i);
    currentTime = currentTrack.Time;
    currentX = currentTrack.XYZ.X;
    currentY = currentTrack.XYZ.Y;
    currentZ = currentTrack.XYZ.Z;
    
    correctedX = currentX;
    correctedY = currentY;
    correctedZ = currentZ;

    for j = 2:numel(currentTime)
        refPrevX = interp1(refTime, refX, currentTime(j-1), 'linear', 'extrap');
        refCurrX = interp1(refTime, refX, currentTime(j), 'linear', 'extrap');
        refPrevY = interp1(refTime, refY, currentTime(j-1), 'linear', 'extrap');
        refCurrY = interp1(refTime, refY, currentTime(j), 'linear', 'extrap');
        refPrevZ = interp1(refTime, refZ, currentTime(j-1), 'linear', 'extrap');
        refCurrZ = interp1(refTime, refZ, currentTime(j), 'linear', 'extrap');

        correctedX(j) = correctedX(j-1) + ...
            (currentX(j) - currentX(j-1)) - (refCurrX - refPrevX);
        correctedY(j) = correctedY(j-1) + ...
            (currentY(j) - currentY(j-1)) - (refCurrY - refPrevY);
        correctedZ(j) = correctedZ(j-1) + ...
            (currentZ(j) - currentZ(j-1)) - (refCurrZ - refPrevZ);
    end

    correctedDataStruct(i).FileName = fileName;
    correctedDataStruct(i).TrackID = currentTrack.TrackID;
    correctedDataStruct(i).Time = currentTime;
    correctedDataStruct(i).XYZ.X = currentX;%correctedX;
    correctedDataStruct(i).XYZ.Y = currentY;%correctedY;
    correctedDataStruct(i).XYZ.Z = currentZ;%correctedZ;
end

if isempty(correctedDataStruct)
    error('No corrected tracks are available to plot.');
end

% Chart settings
zSamplingInterval = 2;
showTrackLabels = false;
cMapName = 'jet';
figureColor = [1 1 1];
axesColor = [1 1 1];
gridColor = [0.42 0.42 0.42];
axisTextColor = [0.18 0.18 0.18];

plotData = repmat(struct('TrackID', [], 'X', [], 'Y', [], 'Z', [], 'DisplayIndex', NaN), ...
    1, numel(correctedDataStruct));
allX = [];
allY = [];
allZ = [];
displayTrackCount = 0;

for i = 1:numel(correctedDataStruct)
    if ~isstruct(correctedDataStruct(i))
        error('correctedDataStruct(%d) is %s, not a struct.', i, class(correctedDataStruct(i)));
    end

    if ~isfield(correctedDataStruct(i), 'XYZ') || ~isstruct(correctedDataStruct(i).XYZ)
        error('correctedDataStruct(%d).XYZ is missing or not a struct.', i);
    end

    if ~isfield(correctedDataStruct(i).XYZ, 'X') || ...
            ~isfield(correctedDataStruct(i).XYZ, 'Y') || ...
            ~isfield(correctedDataStruct(i).XYZ, 'Z')
        error('correctedDataStruct(%d).XYZ does not contain X/Y/Z fields.', i);
    end
    
    [~, sortIdx] = sort(correctedDataStruct(i).Time, 'ascend');
    X = correctedDataStruct(i).XYZ.X(sortIdx);
    Y = correctedDataStruct(i).XYZ.Y(sortIdx);
    Z = correctedDataStruct(i).XYZ.Z(sortIdx);

    validMask = ~(isnan(X) | isnan(Y) | isnan(Z));
    X = X(validMask);
    Y = Y(validMask);
    Z = Z(validMask);

    plotData(i).TrackID = correctedDataStruct(i).TrackID;
    plotData(i).X = X;
    plotData(i).Y = Y;
    plotData(i).Z = Z;
    plotData(i).DisplayIndex = NaN;

    displayTrackCount = displayTrackCount + 1;
    plotData(i).DisplayIndex = displayTrackCount;

    allX = [allX; X];
    allY = [allY; Y];
    allZ = [allZ; Z];
end

if isempty(allX)
    error('All corrected tracks are empty after removing invalid coordinates.');
end

[zDisplayScale, zDisplayCenter] = getZDisplayScale(allX, allY, allZ, zSamplingInterval);
allZDisplay = scaleZForDisplay(allZ, zDisplayCenter, zDisplayScale);
minTrackID = min(trackTable.TRACK_ID);
maxTrackID = max(trackTable.TRACK_ID);
trackColorMap = feval(cMapName, maxTrackID - minTrackID + 1);

% Plot corrected 3D tracks
fig = figure('Color', figureColor, 'WindowStyle', 'normal', 'Toolbar', 'figure');
ax = axes('Parent', fig);
ax.Color = axesColor;
hold(ax, 'on');
grid(ax, 'on');
box(ax, 'on');
view(ax, 3);
pbaspect(ax, [1 1 1]);
ax.GridColor = gridColor;
ax.XColor = axisTextColor;
ax.YColor = axisTextColor;
ax.ZColor = axisTextColor;

for i = 1:numel(plotData)
    X = plotData(i).X;
    Y = plotData(i).Y;
    Z = plotData(i).Z;

    if isempty(X)
        continue;
    end

    ZDisplay = scaleZForDisplay(Z, zDisplayCenter, zDisplayScale);
    trackColor = mapTrackIDToJetColor(plotData(i).TrackID, minTrackID, trackColorMap);
    arrowColor = darkenTrackColor(trackColor, axesColor);

    plot3(ax, X, Y, Z, '-', 'LineWidth', 1, 'Color', trackColor);
    scatter3(ax, X, Y, Z, 10, trackColor, 'filled', ...
        'MarkerFaceAlpha', 0.85, 'MarkerEdgeAlpha', 0.85);

    if numel(X) > 1
        dX = diff(X);
        dY = diff(Y);
        dZ = diff(Z);

        quiver3(ax, X(1:end-1), Y(1:end-1), Z(1:end-1), dX, dY, dZ, 0, ...
            'Color', trackColor, 'LineWidth', 1, 'MaxHeadSize', 0.8);
    end

    scatter3(ax, X(1), Y(1), Z(1), 28, trackColor, 'o', 'filled', ...
        'MarkerEdgeColor', trackColor, 'LineWidth', 0.8);
    scatter3(ax, X(end), Y(end), Z(end), 34, trackColor, '^', 'filled', ...
        'MarkerEdgeColor', trackColor, 'LineWidth', 0.8);

    if showTrackLabels
        text(ax, X(end), Y(end), Z(end), sprintf('   %s|%d', correctedDataStruct(i).FileName, plotData(i).TrackID), ...
            'Color', 'black', 'FontSize', 8, 'FontWeight', 'bold');
    end
end

applyCubeAxisLimits(ax, allX, allY, allZDisplay);
applyZTickLabels(ax, allZ, zSamplingInterval, zDisplayCenter, zDisplayScale);

xlabel(ax, 'Corrected X');
ylabel(ax, 'Corrected Y');
zlabel(ax, 'Z');
title(ax, 'Corrected 3D Cell Tracks (TrackMate Style)', 'Color', axisTextColor);

hold(ax, 'off');

function trackColors = buildTrackMateStylePalette(trackCount)
trackColors = jet(trackCount);
end

function trackColor = mapTrackIDToJetColor(trackID, minTrackID, trackColorMap)
trackMateColorOverrides = [
    0, 0.6980, 0.1843, 0.6078
    1, 0.4157, 0.6196, 0.7255
    2, 0.8392, 0.8980, 0.7922
    3, 0.7294, 0.4549, 0.3451
    4, 0.6039, 0.4941, 0.1765
    5, 0.2157, 0.4510, 0.8118
    6, 0.4980, 0.6745, 0.3922
    7, 0.7255, 0.2118, 0.1373
    8, 0.2200, 0.4700, 0.8900
    9, 0.5300, 0.7700, 0.3600
];

overrideRow = find(trackMateColorOverrides(:, 1) == trackID, 1);
if ~isempty(overrideRow)
    trackColor = trackMateColorOverrides(overrideRow, 2:4);
    return;
end

colorIndex = round(trackID - minTrackID + 1);
colorIndex = max(1, min(size(trackColorMap, 1), colorIndex));
trackColor = trackColorMap(colorIndex, :);
end

function arrowColor = darkenTrackColor(trackColor, axesColor)
arrowColor = 0.45 * trackColor + 0.25 * [0.32 0.32 0.32];
arrowColor = 0.65 * arrowColor + 0.15 * axesColor;
arrowColor = min(max(arrowColor, 0), 1);
end

function [zDisplayScale, zDisplayCenter] = getZDisplayScale(X, Y, Z, zSamplingInterval)
xSpan = max(X) - min(X);
ySpan = max(Y) - min(Y);
zSpan = max(Z) - min(Z);

xySpan = max([xSpan, ySpan]);

if xySpan <= 0
    xySpan = 1;
end

zDisplayCenter = mean([min(Z), max(Z)]);

if zSpan <= 0
    zDisplayScale = 6;
    return;
end

targetZSpan = max(xySpan, 6 * zSamplingInterval);
zDisplayScale = targetZSpan / max(zSpan, zSamplingInterval);
zDisplayScale = max(zDisplayScale, 1);
end

function ZDisplay = scaleZForDisplay(Z, zDisplayCenter, zDisplayScale)
ZDisplay = zDisplayCenter + (Z - zDisplayCenter) .* zDisplayScale;
end

function applyCubeAxisLimits(ax, X, Y, ZDisplay)
xRange = [min(X), max(X)];
yRange = [min(Y), max(Y)];
zRange = [min(ZDisplay), max(ZDisplay)];

cubeRange = max([diff(xRange), diff(yRange), diff(zRange)]);

if cubeRange <= 0
    cubeRange = 1;
end

padding = cubeRange * 0.08;
halfSpan = cubeRange / 2 + padding;

xCenter = mean(xRange);
yCenter = mean(yRange);
zCenter = mean(zRange);

xlim(ax, [xCenter - halfSpan, xCenter + halfSpan]);
ylim(ax, [yCenter - halfSpan, yCenter + halfSpan]);
zlim(ax, [zCenter - halfSpan, zCenter + halfSpan]);
end

function applyZTickLabels(ax, Z, zSamplingInterval, zDisplayCenter, zDisplayScale)
zMin = min(Z);
zMax = max(Z);

tickStepMultiplier = max(1, ceil((zMax - zMin) / (8 * zSamplingInterval)));
tickStep = zSamplingInterval * tickStepMultiplier;

tickStart = floor(zMin / tickStep) * tickStep;
tickEnd = ceil(zMax / tickStep) * tickStep;
zTickValues = tickStart:tickStep:tickEnd;

if isempty(zTickValues)
    zTickValues = zMin;
end

zTickDisplay = scaleZForDisplay(zTickValues, zDisplayCenter, zDisplayScale);
ax.ZTick = zTickDisplay;
ax.ZTickLabel = string(zTickValues);
end
